package hanghoa;

import javax.ws.rs.core.Response;
import javax.ws.rs.*;

@Path("/hanghoa")
public class HangHoaService implements IHangHoa {
	private static HangHoaImpl hangHoaImpl = new HangHoaImpl();

	@Override
	@POST
	@Path("/themHangHoa")
	public Response themHangHoa(ChiTiet chiTiet) {
		return hangHoaImpl.themHangHoa(chiTiet);
	}

	@Override
	@POST
	@Path("/capNhatHangHoa")
	public Response chinhSuaHangHoa(ChiTiet chiTiet) {
		return hangHoaImpl.chinhSuaHangHoa(chiTiet);
	}

	@Override
	@POST
	@Path("/xoaHangHoa")
	public Response xoaHangHoa(ChiTiet chiTiet) {
		return hangHoaImpl.xoaHangHoa(chiTiet);
	}

	@Override
	@POST
	@Path("/chiTiet")
	public Response xemChiTiet(String maSo) {
		return hangHoaImpl.xemChiTiet(maSo);
	}

	@Override
	@POST
	@Path("/danhSach")
	public Response getDanhSach() {
		return hangHoaImpl.getDanhSach();
	}

}
