package hanghoa;

public class ChiTietDTO {
	private String maSo;
	private String tieuDe;
	private String tenNhanVien;
	private int soLuong;
	private double donGia;
	
	public ChiTietDTO() {
		super();
	}

	public ChiTietDTO(String maSo, String tieuDe, String tenNhanVien, int soLuong, double donGia) {
		super();
		this.maSo = maSo;
		this.tieuDe = tieuDe;
		this.tenNhanVien = tenNhanVien;
		this.soLuong = soLuong;
		this.donGia = donGia;
	}
	
	
	
}
