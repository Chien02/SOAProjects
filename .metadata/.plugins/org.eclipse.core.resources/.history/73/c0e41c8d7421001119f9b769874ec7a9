package qlnh;

import java.util.List;

import javax.ws.rs.*;
import javax.ws.rs.core.GenericEntity;
import javax.ws.rs.core.MediaType;
import javax.ws.rs.core.Response;

@Path("/nganhang")
@Produces(MediaType.APPLICATION_JSON)
@Consumes(MediaType.APPLICATION_JSON)
public class QuanLyNganHangSerivce {
	private static final QuanLyNganHang quanLy = new QuanLyNganHang();
	
	// Dang nhap
	@POST
	@Path("/dangnhap")
	public Response dangNhap(GiaoDichRequest req) {
		String soTK = req.getSoTaiKhoanNhan();
		String maPin = req.getMaPin();
		
		TaiKhoanNganHang taiKhoan = quanLy.timTaiKhoanTheoSo(soTK);
		if (taiKhoan == null) {
			return Response.status(Response.Status.NOT_FOUND).entity("Khong tim thay tai khoan").build();
		}
		if (!taiKhoan.kiemTraMaPin(maPin)) {
			return Response.status(Response.Status.UNAUTHORIZED).entity("Sai ma pin").build();
		}
		return Response.ok(taiKhoan).build();
	}
	
	// Hien thi thong tin cua tai khoan
	@POST
	@Path("/thongtin")
	public Response thongTinTaiKhoan(GiaoDichRequest req) {
		String soTK = req.getSoTaiKhoanNhan();
		String maPin = req.getMaPin();
		
		TaiKhoanNganHang taiKhoan = quanLy.timTaiKhoanTheoSo(soTK);
		if (taiKhoan == null) {
			return Response.status(Response.Status.NOT_FOUND).entity("Khong tim thay tai khoan").build();
		}
		return Response.ok(taiKhoan).build();
	}
	
	// Nap tien
	@POST
	@Path("/naptien")
	public Response napTien(GiaoDichRequest req) {
		String soTK = req.getSoTaiKhoan();
		TaiKhoanNganHang taiKhoan = quanLy.timTaiKhoanTheoSo(soTK);
		
		if (taiKhoan == null) {
			return Response.status(Response.Status.NOT_FOUND).entity("Khong tim thay tai khoan").build();
		}
		
		if (!taiKhoan.napTien(req.getSoTien(), req.getMaPin())) {
			return Response.status(Response.Status.NOT_ACCEPTABLE).entity("So tien loi hoac sai ma pin").build();
		}
		
		return Response.ok(taiKhoan).build();
	}
	
	// Rut tien
	@POST
	@Path("/ruttien")
	public Response rutTien(GiaoDichRequest req) {
		String soTK = req.getSoTaiKhoan();
		TaiKhoanNganHang taiKhoan = quanLy.timTaiKhoanTheoSo(soTK);
		
		if (taiKhoan == null) {
			return Response.status(Response.Status.NOT_FOUND).entity("Khong tim thay tai khoan").build();
		}
		
		if (!taiKhoan.rutTien(req.getSoTien(), req.getMaPin())) {
			return Response.status(Response.Status.NOT_ACCEPTABLE).entity("So tien loi hoac sai ma pin").build();
		}
		
		return Response.ok(taiKhoan).build();
	}
	
	// Chuyen tien
	@POST
	@Path("/chuyentien")
	public Response chuyenTien(GiaoDichRequest req) {
		String soTK = req.getSoTaiKhoan();
		String soTKNhan = req.getSoTaiKhoanNhan();
		Double soTien = req.getSoTien();
		String maPin = req.getMaPin();
		
		TaiKhoanNganHang taiKhoan = quanLy.timTaiKhoanTheoSo(soTK);
		TaiKhoanNganHang taiKhoanNhan = quanLy.timTaiKhoanTheoSo(soTKNhan);
		if (taiKhoan == null || taiKhoanNhan == null) {
			return Response.status(Response.Status.NOT_FOUND).entity("Khong tim thay tai khoan hoac tai khoan nhan").build();
		}
		
		if (!taiKhoan.chuyenTien(taiKhoanNhan, soTien, maPin)) {
			return Response.status(Response.Status.BAD_REQUEST).entity("Loi chuyen tien").build();
		}
		return Response.ok(taiKhoan).build();
	}
	
	// Hien thi danh sach
	@GET
	@Path("/danhsach")
	@Produces(MediaType.APPLICATION_JSON)
	public Response hienThiTatCa() {
		List<TaiKhoanNganHang> danhSach = quanLy.hienThiTatCa();
		GenericEntity<List<TaiKhoanNganHang>> entity = new GenericEntity<List<TaiKhoanNganHang>>(danhSach) {};
		return Response.ok(entity).build();
	}
	
	// Them tai khoan
    @POST
    @Path("/themtaikhoan")
    public Response themTaiKhoan(GiaoDichRequest req) {
        TaiKhoanNganHang taiKhoanMoi = new TaiKhoanNganHang(
            req.getSoTaiKhoan(), 
            req.getChuTaiKhoan(), 
            0.0, 
            req.getMaPin(), 
            req.isLaAdmin()
        );
        
        if (quanLy.themTaiKhoan(taiKhoanMoi)) {
            return Response.status(Response.Status.CREATED).entity("Tao tai khoan thanh cong").build();
        }
        return Response.status(Response.Status.CONFLICT).entity("Tai khoan da ton tai").build();
    }
    
    // Tim kiem tai khoan theo soTK
    @POST
    @Path("/timtaikhoan/{soTK}")
    public Response timTaiKhoan(@PathParam("soTK") String soTK) {
    	TaiKhoanNganHang result = quanLy.timTaiKhoanTheoSo(soTK);
    	
    	if (result != null) {
    		return Response.ok(result).build();
    	}
    	return Response.status(Response.Status.BAD_REQUEST).entity("Khong tim thay tai khoan").build();
    }
}
