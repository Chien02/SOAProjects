/* =========================================
   1. BỐ CỤC CHUNG (GRID)
   ========================================= */
body {
    margin: 0;
    padding: 0;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: #f4f7f6;
    color: #333;
    display: grid;
    grid-template-columns: 250px 1fr;
    grid-template-rows: auto 1fr;
    min-height: 100vh;
}

h2 {
    grid-column: 1 / 3;
    background-color: #2c3e50;
    color: #ffffff;
    margin: 0;
    padding: 20px;
    text-align: center;
    letter-spacing: 1px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    z-index: 10;
}

/* =========================================
   2. FIX LỖI SIDEBAR (ASIDE)
   ========================================= */
aside {
    background-color: #34495e; /* Màu nền tối giống trong ảnh của bạn */
    display: flex;
    flex-direction: column;
    padding-top: 20px;
}

aside a {
    display: block; /* Bắt buộc để thẻ a chiếm hết chiều ngang */
    width: 100%;
    box-sizing: border-box;
    color: #ecf0f1;
    text-decoration: none;
    padding: 15px 25px;
    font-size: 16px;
    text-align: left; /* FIX: Ép tất cả chữ canh sát lề trái, không bị lởm chởm */
    border-left: 4px solid transparent;
    transition: all 0.3s ease;
}

aside a:hover, 
aside a.active { /* Class active để bôi đậm trang hiện tại giống chữ "Trang chủ" trong ảnh */
    background-color: #2c3e50;
    border-left: 4px solid #3498db;
    padding-left: 30px; /* Hiệu ứng thụt nhẹ vào khi trỏ chuột */
}

