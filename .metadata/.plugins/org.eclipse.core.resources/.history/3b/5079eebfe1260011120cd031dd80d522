/* =========================================
   CÀI ĐẶT CHUNG (Trang Đăng Nhập)
   ========================================= */
body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: #f4f7f6;
    color: #333;
    margin: 0;
    
    /* Dùng Flexbox để căn giữa toàn bộ nội dung ra giữa màn hình */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100vh;
}

h2 {
    color: #2c3e50;
    margin-bottom: 20px;
    text-align: center;
    font-size: 28px;
}

/* =========================================
   FORM ĐĂNG NHẬP
   ========================================= */
form {
    background-color: #ffffff;
    padding: 40px;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    width: 100%;
    max-width: 350px;
    display: flex;
    flex-direction: column; /* Xếp các input dọc xuống */
}

form label {
    font-weight: bold;
    margin-bottom: 8px;
    color: #2c3e50;
}

form input[type="text"],
form input[type="password"] {
    padding: 8px;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 15px;
    outline: none;
    transition: border 0.3s;
    margin-bottom: 20px; /* Tạo khoảng cách mà không cần thẻ <br> trong HTML */
    width: 100%;
    box-sizing: border-box; /* Giúp padding không làm tràn chiều rộng */
}

form input[type="text"]:focus,
form input[type="password"]:focus {
    border-color: #3498db;
    box-shadow: 0 0 5px rgba(52, 152, 219, 0.3);
}

/* =========================================
   NÚT BẤM & LIÊN KẾT
   ========================================= */
button {
    background-color: #3498db;
    color: white;
    border: none;
    padding: 14px;
    font-size: 16px;
    border-radius: 4px;
    cursor: pointer;
    font-weight: bold;
    transition: background 0.3s;
    width: 100%;
    margin-top: 10px;
}

button:hover {
    background-color: #2980b9;
}

form p {
    text-align: center;
    margin-top: 25px;
    margin-bottom: 0;
    font-size: 14.5px;
}

form p a {
    color: #3498db;
    text-decoration: none;
    font-weight: bold;
    transition: color 0.2s;
}

form p a:hover {
    color: #2980b9;
    text-decoration: underline;
}

/* =========================================
   THÔNG BÁO LỖI (Trang trí lại cho đẹp)
   ========================================= */
p[style*="color: red;"] {
    background-color: #ffebee;
    color: #c62828 !important; /* Đè lại màu đỏ mặc định của bạn cho dịu mắt hơn */
    padding: 12px;
    border-radius: 4px;
    border: 1px solid #ef9a9a;
    margin-bottom: 20px;
    width: 100%;
    max-width: 350px;
    box-sizing: border-box;
    text-align: center;
    font-weight: bold;
    display: none; /* Ẩn đi mặc định */
}

/* Chỉ hiện thông báo lỗi khi có nội dung bên trong */
p[style*="color: red;"]:not(:empty) {
    display: block;
}