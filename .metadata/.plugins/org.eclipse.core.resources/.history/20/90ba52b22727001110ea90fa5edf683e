<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<%@ taglib prefix="fmt" uri="http://java.sun.com/jsp/jstl/fmt" %>

<!DOCTYPE html>
<html>
<head>
	<meta charset="UTF-8">
	<title>QUẢN LÝ NGƯỜI DÙNG</title>
	<link rel="stylesheet" href="styles/styles.css">
</head>
<body>
	<h2>HỆ THỐNG QUẢN TRỊ ADMIN</h2>
	<aside>
		<a href="customer?action=khoHang">Trang chủ</a>
		<a href="userInfo.jsp">Tài khoản</a>
		
		<c:if test="${khachHang != null && khachHang.laAdmin}">
			<a href="hanghoa?action=inventory">Quản lý Kho Hàng</a>
			<a href="customer?action=danhSach" class="active">Quản lý Người Dùng</a> 
		</c:if>
		
		<a href="customer?action=dangXuat">Đăng xuất</a>
	</aside>
	<main>
		<div class="section-header">
            <h2 class="section-title">Danh Sách Người Dùng Hệ Thống</h2>
            <span class="goods-count">Tổng cộng: ${danhSach.size()} tài khoản</span> 
        </div>

        <c:if test="${not empty errorMsg}">
            <div class="msg-alert msg-error">${errorMsg}</div>
        </c:if>
        <c:if test="${not empty successMsg}">
            <div class="msg-alert msg-success">${successMsg}</div>
        </c:if>

		<table class="cart-table">
            <thead>
                <tr>
                    <th>STT</th>
                    <th>CCCD</th>
                    <th>Họ và Tên</th>
                    <th>Địa Chỉ</th>
                    <th style="text-align: center;">Vai Trò</th>
                    <th style="text-align: center;">Hạng Thành Viên</th>
                    <th style="text-align: center;">Thao Tác</th>
                    <th style="text-align: center;">Lịch Sử</th>
                </tr>
            </thead>
            <tbody>
                <c:forEach items="${danhSach}" var="u" varStatus="loop">
                    <tr>
                        <td>${loop.index + 1}</td>
                        <td>${u.cccd}</td>
                        <td><strong>${u.hoTen}</strong></td>
                        <td>${u.diaChi}</td>
                        <td style="text-align: center;">
                            <c:choose>
                                <c:when test="${u.laAdmin}">
                                    <span style="background-color: #e74c3c; color: white; padding: 4px 10px; border-radius: 20px; font-size: 13px; font-weight: bold;">Admin</span>
                                </c:when>
                                <c:otherwise>
                                    <span style="background-color: #3498db; color: white; padding: 4px 10px; border-radius: 20px; font-size: 13px; font-weight: bold;">Khách Hàng</span>
                                </c:otherwise>
                            </c:choose>
                        </td>
                        <td style="text-align: center;">
                            <c:choose>
                                <c:when test="${u.vip}">
                                    <span style="color: #f39c12; font-weight: bold; font-size: 15px;">⭐ VIP</span>
                                </c:when>
                                <c:otherwise>
                                    <span style="color: #7f8c8d;">Thường</span>
                                </c:otherwise>
                            </c:choose>
                        </td>
                        <td style="text-align: center;">
                            <c:set var="fmtNgayVip"><fmt:formatDate value="${u.ngayVip}" pattern="yyyy-MM-dd"/></c:set>
                            <c:set var="fmtNgayHetHan"><fmt:formatDate value="${u.ngayHetHanVip}" pattern="yyyy-MM-dd"/></c:set>
                            
                        	<button type="button" class="btn-edit" 
                        		onclick="openEditModal('${u.cccd}', '${u.hoTen}','${u.diaChi}', '${u.laAdmin}', ${u.vip}, '${fmtNgayVip}', '${fmtNgayHetHan}', '${u.tiLeGiam}')">Sửa</button>
                        </td>
                        <td><button id="historyBtn" onclick="invoice?action=history&id=${u.cccd}">Xem</button></td>
                    </tr>
                </c:forEach>
            </tbody>
        </table>
	</main>
	
	<div id="editModal" class="modal" style="display: none;">
        <div class="modal-content">
            <span class="close-btn" onclick="document.getElementById('editModal').style.display='none'">&times;</span>
            <h3>Cập nhật Khách hàng (Admin)</h3>
            
            <form action="customer" method="POST">
                <input type="hidden" name="action" value="adminUpdateUser">
                
                <label>CCCD (Không thể sửa):</label>
                <input type="text" name="cccd" id="editMaSo" readonly style="background: #f1f1f1;" required>
                
                <label>Họ tên:</label>
                <input type="text" name="hoTen" id="editHoTen" required>
                
                <label>Địa chỉ:</label>
                <input type="text" name="diaChi" id="editDiaChi" required>
                
                <label>Quyền quản trị:</label>
                <select name="laAdmin" id="editLaAdmin" style="padding: 10px; border: 1px solid #ccc; border-radius: 4px; font-size: 15px; margin-bottom: 10px;" required>
                    <option value="true">Có (Là Admin)</option>
                    <option value="false">Không (Khách hàng thường)</option>
                </select>
                
                <label>Trạng thái VIP:</label>
                <select name="vip" id="editVip" style="padding: 10px; border: 1px solid #ccc; border-radius: 4px; font-size: 15px; margin-bottom: 10px;" required>
                    <option value="true">Có (Khách hàng VIP)</option>
                    <option value="false">Không (Khách hàng thường)</option>
                </select>
                
                <label>Ngày trở thành VIP:</label>
                <input type="date" name="ngayVip" id="editNgayVip" style="padding: 10px; border: 1px solid #ccc; border-radius: 4px; width: 100%; box-sizing: border-box; margin-bottom: 10px;">
                
                <label>Ngày hết hạn VIP:</label>
                <input type="date" name="ngayHetHanVip" id="editNgayHetHanVip" style="padding: 10px; border: 1px solid #ccc; border-radius: 4px; width: 100%; box-sizing: border-box; margin-bottom: 10px;">
                
                <label>Tỉ lệ giảm giá (%):</label>
                <input type="number" name="tiLeGiam" id="editTiLeGiam" min="0" max="100" required>
                
                <button type="submit" style="background: #f39c12; margin-top: 20px;">Lưu Cập Nhật</button>
            </form>
        </div>
    </div>

    <script>
        // Hàm được gọi khi bấm nút Sửa trên bảng
        function openEditModal(cccd, hoTen, diaChi, isLaAdmin, isVip, ngayVip, ngayHetHanVip, tiLeGiam) {
            document.getElementById('editMaSo').value = cccd;
            document.getElementById('editHoTen').value = hoTen;
            document.getElementById('editDiaChi').value = diaChi;
            
            document.getElementById('editLaAdmin').value = isLaAdmin ? "true" : "false";
            
            // Xử lý select VIP (isVip là boolean)
            document.getElementById('editVip').value = isVip ? "true" : "false";
            
            // Đổ ngày tháng vào (chỉ nhận định dạng yyyy-MM-dd)
            document.getElementById('editNgayVip').value = ngayVip;
            document.getElementById('editNgayHetHanVip').value = ngayHetHanVip;
            
            // Đổ tỉ lệ giảm giá (mặc định để 10 nếu rỗng)
            document.getElementById('editTiLeGiam').value = tiLeGiam ? tiLeGiam : 10;
            
            document.getElementById('editModal').style.display = 'block';
        }
        
        // Đóng khi click ra ngoài vùng nền mờ
        window.addEventListener('click', function(e) {
            if (e.target == document.getElementById('editModal')) {
                document.getElementById('editModal').style.display = 'none';
            }
        });
    </script>
</body>
</html>