/* Reset cơ bản và thiết lập font chữ */
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: #f0f4f8; /* Màu nền xám xanh nhạt */
    color: #333;
    line-height: 1.6;
    /* Căn giữa toàn bộ khung chứa nội dung */
    max-width: 650px;
    margin: 40px auto;
    padding: 30px;
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
}

/* Định dạng các tiêu đề */
h3 {
    color: #2c3e50;
    border-bottom: 2px solid #3498db;
    padding-bottom: 8px;
    margin-bottom: 20px;
    margin-top: 30px;
    text-transform: uppercase;
    font-size: 1.2rem;
}

h3:first-child {
    margin-top: 0;
}

h4 {
    color: #34495e;
    margin-bottom: 15px;
    font-size: 1rem;
}

/* Biến mỗi form thành một khung (card) riêng biệt */
form {
    background-color: #f8fafc;
    padding: 20px;
    border-radius: 8px;
    border: 1px solid #e2e8f0;
    margin-bottom: 25px;
    transition: box-shadow 0.3s ease;
}

form:hover {
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.03);
}

/* Căn chỉnh nhãn và ô nhập liệu */
label {
    font-weight: 600;
    margin-right: 5px;
    color: #4a5568;
}

input[type="number"] {
    padding: 10px 12px;
    margin-right: 15px;
    border: 1px solid #cbd5e0;
    border-radius: 6px;
    font-size: 14px;
    width: 90px;
    transition: border-color 0.3s, box-shadow 0.3s;
}

input[type="number"]:focus {
    border-color: #3498db;
    box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.2);
    outline: none;
}

/* Định dạng nút bấm chung */
button {
    padding: 10px 20px;
    background-color: #3498db;
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 15px;
    font-weight: bold;
    cursor: pointer;
    transition: background-color 0.2s, transform 0.1s;
    margin-right: 8px;
}

button:hover {
    background-color: #2980b9;
}

button:active {
    transform: scale(0.96);
}

/* Tùy chỉnh riêng cho 4 nút Cộng, Trừ, Nhân, Chia để nhìn giống máy tính */
button[value="cong"],
button[value="tru"],
button[value="nhan"],
button[value="chia"] {
    width: 20px;
    height: 20px;
    padding: 0;
    margin-top: 15px;
    font-size: 20px;
}

/* Định dạng khu vực hiển thị kết quả */
p, label:has(+ br) {
    font-weight: bold;
    color: #27ae60;
    margin-top: 15px;
    display: inline-block;
}

p {
    display: block;
    padding: 12px;
    background: #e8f8f5;
    border-radius: 6px;
    border-left: 4px solid #27ae60;
}