<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
	<meta charset="UTF-8">
	<title>KHO HANG HOA</title>
	<link rel="stylesheet" href="style.css">
</head>
<body>
	<h2>THÔNG TIN NGƯỜI DÙNG</h2>
	<aside>
		<a href="#">Trang chủ</a>
		<a href="payment?action=cart">Giỏ hàng</a>
		<a href="#">Tài khoản</a>
		<a href="customer?action=logout">Đăng xuất</a>
		<c:if test="${customer.laAdmin}">
			<a href="hanghoa?action=inventory">Kho Hàng</a>
		</c:if>
	</aside>
	<main>
		<div>
			<p>CCCD: ${khachHang.cccd}</p>
			<p>Tên người dùng: ${khachHang.hoTen}</p>
			<p>Địa chỉ: ${khachHang.diaChi}</p>
			<p>Là Admin: ${khachHang.laAdmin}</p>
		</div>
		<button id="updateBtn">Chỉnh sửa thông tin</button>
		<div id="updateModal">
			<h3>Cập nhật thông tin</h3>
			<form action="customer" method="POST">
				<label>CCCD: </label>
				<input type="text" name="cccd" placeholder="Nhập cccd mới" value="${khachHang != null ? khachHang.cccd : ''}" required>
				<label>Họ và tên:</label>
				<input name="hoTen" type="text" placeholder="Nhập họ tên mới" value="${khachHang != null ? khachHang.hoTen : ''}" required>
				<label>Địa chỉ: </label>
				<input type="text" name="diaChi" placeholder="Nhập địa chỉ mới" value="${khachHang != null ? khachHang.diaChi : ''}" required>
				<button type="submit" name="capNhat">Cập nhật</button>
			</form>
		</div>
	</main>
</body>
<script>
	updateBtn = document.getElmentById("updateBtn");
	
	
</script>
</html>