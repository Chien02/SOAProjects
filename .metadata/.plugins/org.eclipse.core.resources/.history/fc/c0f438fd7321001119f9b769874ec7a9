<%@ page contentType="text/html; charset=UTF-8" language="java" %>
<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c" %>
<%@ taglib uri="http://java.sun.com/jsp/jstl/fmt" prefix="fmt" %>

<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>QUAN LY NGAN HANG</title>
    <link href="style.css" rel="stylesheet"/>
</head>
<body>
    <h1>Xin chao ${taiKhoan.chuTaiKhoan}</h1>
    
    <table class="masterTable">
        <thead>
            <tr>
                <th><h3>TUY CHON</h3></th>
                <th class="functionTHead"><h3>DANH SACH TAI KHOAN</h3></th>
            </tr>
        </thead>
        <tbody>
            <tr> <td> <a href="QLNHangWebClient?action=thongtin">THONG TIN</a> </td>
                
                <td rowspan="7" style="vertical-align: top;">
                    
                    <c:if test="${not empty danhSachTK}">
                        <table class="ds-table" border="1" style="border-collapse: collapse; width: 100%;">
                            <thead>
                                <tr>
                                    <th>So Tai Khoan</th>
                                    <th>Chu tai khoan</th>
                                    <th>So Du</th>
                                    <th>Quyen quan tri</th>
                                </tr>
                            </thead>
                            <tbody>
                                <c:forEach items="${danhSachTK}" var="tk">
                                    <tr>
                                        <td>${tk.soTaiKhoan}</td>
                                        <td>${tk.chuTaiKhoan}</td>
                                        <td class="text-right">
                                            <fmt:formatNumber value="${tk.soDu}" pattern="#,### VND" />
                                        </td>
                                        <td>
                                            <c:choose>
                                                <c:when test="${tk.laAdmin}">Co</c:when>
                                                <c:otherwise>Khong</c:otherwise>
                                            </c:choose>
                                        </td>
                                    </tr>
                                </c:forEach>
                            </tbody>
                        </table>
                    </c:if>

                    <c:if test="${empty danhSachTK}">
                        <h3 style="color: red; text-align: center;">He thong chua co tai khoan nao</h3>
                    </c:if>

                </td>
            </tr> <tr>
                <td> <a href="QLNHangWebClient?action=naptien">NAP TIEN</a> </td>
            </tr>
            <tr>
                <td> <a href="QLNHangWebClient?action=ruttien">RUT TIEN</a> </td>
            </tr>
            <tr>
                <td> <a href="QLNHangWebClient?action=chuyentien">CHUYEN TIEN</a> </td>
            </tr>
            <c:if test="${taiKhoan.laAdmin}">
                <tr>
                    <td> <a href="QLNHangWebClient?action=danhsach">DANH SACH TAI KHOAN</a> </td>
                </tr>
                <tr>
                    <td> <a href="QLNHangWebClient?action=themtaikhoan">THEM TAI KHOAN</a> </td>
                </tr>
				<tr>
					<td> <a href="QLNHangWebClient?action=timtaikhoan">TIM TAI KHOAN</a> </td>
				</tr>
            </c:if>
            <tr>
                <td> <a href="QLNHangWebClient?action=dangxuat">DANG XUAT</a> </td>
            </tr>
        </tbody>
    </table>
</body>
</html>